{
  "name": "sistema-reservas-distribuido",
  "version": "1.0.0",
  "description": "Sistema distribuido de reservas con 3 nodos simulados",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "node1": "cross-env NODE_ID=1 node src/index.js",
    "node2": "cross-env NODE_ID=2 node src/index.js",
    "node3": "cross-env NODE_ID=3 node src/index.js",
    "all": "npm run node1 & npm run node2 & npm run node3",
    "seed:data": "node src/scripts/seedData.js"
  },
  "keywords": [
    "distributed",
    "reservations",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^9.4.1",
    "mongose": "^0.0.2-security",
    "mssql": "^12.2.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.1"
  }
}
